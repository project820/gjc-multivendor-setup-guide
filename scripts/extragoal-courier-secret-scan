#!/usr/bin/env sh
# extragoal-courier-secret-scan — mandatory Stage 1 secret scan for the courier
# lane: on this lane the bundle leaves the machine, so the scan is
# non-negotiable (fail closed on any hit; a scan error also blocks).
set -eu
F="${1:?usage: extragoal-courier-secret-scan <bundle-file>}"

# Two pattern sets, run with the right case sensitivity for each:
#  - CS (case-sensitive): fixed-prefix tokens whose case is part of the token.
#  - CI (case-insensitive): keyword=value assignments, where the KEY case is
#    irrelevant (api_key / API_KEY / Api_Key) and the VALUE may be quoted OR
#    unquoted. Running these case-insensitively is what closes the lowercase
#    unquoted hole (a lowercase api-key assignment with a bare value).
CS="$(mktemp)"; CI="$(mktemp)"
cleanup() { rm -f "$CS" "$CI"; }
trap cleanup EXIT

cat > "$CS" <<'PATEOF'
-----BEGIN [A-Z ]*PRIVATE KEY-----
AKIA[0-9A-Z]{16}
ghp_[A-Za-z0-9]{36}
gh[oprsu]_[A-Za-z0-9]{20,}
github_pat_[A-Za-z0-9_]{20,}
xox[bpars]-[A-Za-z0-9-]{10,}
sk-[A-Za-z0-9_-]{20,}
AIza[0-9A-Za-z_-]{35}
eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}
PATEOF

# key = quoted value ('"..."' >=8) OR unquoted value (no space/quote, >=8)
cat > "$CI" <<'PATEOF'
(api[_-]?key|api[_-]?secret|access[_-]?token|client[_-]?secret|secret[_-]?key|secret[_-]?access[_-]?key|password|passwd|token)[[:space:]]*[:=][[:space:]]*(['"][^'"]{8,}|[^[:space:]'"]{8,})
PATEOF

s_cs=0; hits_cs="$(grep -nEf "$CS" "$F")" || s_cs=$?
s_ci=0; hits_ci="$(grep -niEf "$CI" "$F")" || s_ci=$?

# fail closed on any grep error (status >= 2)
if [ "$s_cs" -ge 2 ] || [ "$s_ci" -ge 2 ]; then
  echo "secret scan errored (grep exit cs=$s_cs ci=$s_ci) — fail closed, do NOT send the bundle" >&2
  exit 2
fi
# hit on either set blocks
if [ "$s_cs" -eq 0 ] || [ "$s_ci" -eq 0 ]; then
  echo "BLOCKED: potential secret material in bundle — remove/redact from history or get an explicit user waiver, then re-pack:" >&2
  { [ "$s_cs" -eq 0 ] && printf '%s\n' "$hits_cs"; [ "$s_ci" -eq 0 ] && printf '%s\n' "$hits_ci"; } | head -20 >&2
  exit 1
fi
echo "secret scan: clean ($F)"
exit 0
