#!/usr/bin/env sh
# extragoal-courier-secret-scan — mandatory Stage 1 secret scan for the courier
# lane: on this lane the bundle leaves the machine, so the scan is
# non-negotiable (fail closed on any hit; a scan error also blocks).
set -eu
F="${1:?usage: extragoal-courier-secret-scan <bundle-file>}"
TMP="$(mktemp)"
cat > "$TMP" <<'PATEOF'
-----BEGIN [A-Z ]*PRIVATE KEY-----
AKIA[0-9A-Z]{16}
ghp_[A-Za-z0-9]{36}
gh[oprsu]_[A-Za-z0-9]{20,}
github_pat_[A-Za-z0-9_]{20,}
xox[bpars]-[A-Za-z0-9-]{10,}
sk-[A-Za-z0-9_-]{20,}
AIza[0-9A-Za-z_-]{35}
eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}
(api[_-]?key|api[_-]?secret|access[_-]?token|client[_-]?secret|secret[_-]?key|password|passwd|token)[[:space:]]*[:=][[:space:]]*['"][^'"]{8,}
(API[_-]?KEY|API[_-]?SECRET|ACCESS[_-]?TOKEN|CLIENT[_-]?SECRET|SECRET[_-]?KEY|SECRET[_-]?ACCESS[_-]?KEY|PASSWORD|PASSWD|TOKEN)[[:space:]]*=[[:space:]]*[^[:space:]'"]{8,}
PATEOF
status=0
hits="$(grep -nEf "$TMP" "$F")" || status=$?
rm -f "$TMP"
if [ "$status" -eq 0 ]; then
  echo "BLOCKED: potential secret material in bundle — remove/redact from history or get an explicit user waiver, then re-pack:" >&2
  printf '%s\n' "$hits" | head -20 >&2
  exit 1
elif [ "$status" -eq 1 ]; then
  echo "secret scan: clean ($F)"
  exit 0
else
  echo "secret scan errored (grep exit $status) — fail closed, do NOT send the bundle" >&2
  exit 2
fi
